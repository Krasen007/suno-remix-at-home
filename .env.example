# Environment Variables
# IMPORTANT: Never commit your real .env file to version control (Git).
SUNO_API_KEY=your_suno_api_key_here

# GitHub Configuration (for automatic file hosting)
# Create a Personal Access Token at https://github.com/settings/tokens (Classic)
# Required Scope: "repo" (for private/public repos) or "public_repo" (for public only)
# Token with 'repo' scope
GITHUB_TOKEN=your_github_personal_access_token 
# Your GitHub username or organization
GITHUB_OWNER=your_github_username     
# Name of the repo where tracks will be hosted         
GITHUB_REPO=your_suno_remix_repo_name     
# Target branch (usually 'main' or 'master')     
GITHUB_BRANCH=main                             
